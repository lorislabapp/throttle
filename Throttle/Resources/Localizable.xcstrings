    "Three more cards — when (and where) you burn tokens, how much the hooks saved you, and a one-tap shareable badge.": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trois cartes supplémentaires — quand (et où) vous brûlez des tokens, combien les hooks vous ont fait économiser, et un badge partageable en un clic."
          }
        }
      }
    },
