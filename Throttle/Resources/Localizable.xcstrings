    "Setup (one-time):": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Installation (une seule fois) :"
          }
        }
      }
    },
    "Throttle asks your signed-in Safari to fetch your usage data. Safari handles the cookies and signing — we just read the result. Nothing leaves your Mac.": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Throttle demande à votre Safari connecté de récupérer vos données d'utilisation. Safari gère les cookies et la signature — nous lisons juste le résultat. Rien ne sort de votre Mac."
          }
        }
      }
    },
    "Logs include app behaviour only — no session content.": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les journaux contiennent uniquement le comportement de l'app — aucun contenu de session."
          }
        }
      }
    },
    "Bundle anonymized stats (event counts, hook status, last error) into a .zip on your Desktop. No usage content, no model details — token totals only. For support requests.": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Empaquète des stats anonymisées (compteurs d'événements, état des hooks, dernière erreur) dans un .zip sur votre bureau. Aucun contenu d'utilisation, aucun détail de modèle — uniquement des totaux de tokens. Pour les demandes de support."
          }
        }
      }
    },
    "Estimated API cost: %@": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Coût API estimé : %@"
          }
        }
      }
    },
    "(What this would have cost on the developer API at Anthropic's published rates.)": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "(Ce que cela aurait coûté sur l'API développeur aux tarifs publics d'Anthropic.)"
          }
        }
      }
    },
    "No history yet — keep using Claude Code, the chart fills as you go.": {
      "extractionState": "manual",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas encore d'historique — continuez à utiliser Claude Code, le graphique se remplit au fil du temps."
          }
        }
      }
    },
